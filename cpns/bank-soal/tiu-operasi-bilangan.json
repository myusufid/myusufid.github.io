    {
      "id": 1,
      "question": "4 - 7/5 + 3/10 = ...",
      "options": {
        "A": "2,5",
        "B": "2,7",
        "C": "2,9",
        "D": "3",
        "E": "3,2"
      },
      "answer": "C",
      "explanation": "Samakan penyebut ke 10: 4 = 40/10, 7/5 = 14/10, 3/10 = 3/10. Hasil = 40/10 - 14/10 + 3/10 = 29/10 = 2,9."
    },
    {
      "id": 2,
      "question": "4/7 ÷ 6/7 + 4 × 1/3 - 2/5 = ...",
      "options": {
        "A": "6/5",
        "B": "8/5",
        "C": "9/5",
        "D": "10/11",
        "E": "9/13"
      },
      "answer": "B",
      "explanation": "Langkah 1: 4/7 ÷ 6/7 = 4/7 × 7/6 = 4/6 = 2/3. Langkah 2: 4 × 1/3 = 4/3. Langkah 3: 2/3 + 4/3 = 6/3 = 2. Langkah 4: 2 - 2/5 = 10/5 - 2/5 = 8/5."
    }
  ]
}
